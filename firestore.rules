rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'lunaheloisaa82@gmail.com'
        && request.auth.token.email_verified == true;
    }

    function isValidString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }

    function isValidCanais(array) {
      return array is list && array.size() <= 20;
    }

    function empresaToken(empresaId) {
      return get(/databases/$(database)/documents/empresas/$(empresaId)).data.token;
    }

    // ===============================================================
    // Config (admin only)
    // ===============================================================
    match /config/{docId} {
      allow read, write: if isAdmin();
    }

    // ===============================================================
    // Empresas
    // ===============================================================
    match /empresas/{empresaId} {
      allow read: if true;

      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly(['nome', 'slug', 'token', 'criadoEm', 'locale'])
        && isValidString(request.resource.data.nome, 1, 100)
        && isValidString(request.resource.data.slug, 1, 100)
        && isValidString(request.resource.data.token, 32, 32)
        && request.resource.data.criadoEm is timestamp;

      allow update: if isAdmin()
        && request.resource.data.keys().hasOnly(['nome'])
        && isValidString(request.resource.data.nome, 1, 100);

      allow delete: if isAdmin();

      // ===============================================================
      // Pessoas (subcollection)
      // ===============================================================
      match /pessoas/{pessoaId} {
        allow read: if true;

        allow create: if isAdmin()
          && request.resource.data.keys().hasOnly(['nome', 'token', 'ordem', 'criadoEm'])
          && isValidString(request.resource.data.nome, 1, 100)
          && isValidString(request.resource.data.token, 32, 32)
          && request.resource.data.ordem is number
          && request.resource.data.criadoEm is timestamp;

        allow update: if isAdmin()
          && request.resource.data.keys().hasOnly(['nome'])
          && isValidString(request.resource.data.nome, 1, 100);

        allow delete: if isAdmin();

        // ===============================================================
        // Videos (subcollection)
        // ===============================================================
        match /videos/{videoId} {
          allow read: if true;

          allow create: if isAdmin()
            && request.resource.data.keys().hasOnly(['titulo', 'status', 'ordem', 'criadoEm', 'atualizadoEm', 'dataPostagem', 'canais', 'ads', 'observacoes', 'priorizado', 'linkMaterialBruto', 'linkVideoFinal', 'valor', 'moeda'])
            && isValidString(request.resource.data.titulo, 1, 200)
            && request.resource.data.status in ['gravado', 'editando', 'revisao', 'postado']
            && request.resource.data.ordem is number
            && isValidCanais(request.resource.data.canais)
            && request.resource.data.ads is bool
            && isValidString(request.resource.data.observacoes, 0, 2000)
            && (request.resource.data.dataPostagem is timestamp || request.resource.data.dataPostagem == null)
            && request.resource.data.criadoEm is timestamp
            && request.resource.data.priorizado is bool
            && isValidString(request.resource.data.linkMaterialBruto, 0, 2048)
            && isValidString(request.resource.data.linkVideoFinal, 0, 2048);

          allow update: if (isAdmin()
            && request.resource.data.keys().hasOnly(['titulo', 'status', 'canais', 'ads', 'observacoes', 'dataPostagem', 'ordem', 'priorizado', 'linkMaterialBruto', 'linkVideoFinal', 'atualizadoEm', 'valor', 'moeda'])
            && (!request.resource.data.keys().hasAny(['atualizadoEm']) || request.resource.data.atualizadoEm is timestamp)
            && (!request.resource.data.keys().hasAny(['titulo']) || isValidString(request.resource.data.titulo, 1, 200))
            && (!request.resource.data.keys().hasAny(['status']) || request.resource.data.status in ['gravado', 'editando', 'revisao', 'postado'])
            && (!request.resource.data.keys().hasAny(['canais']) || isValidCanais(request.resource.data.canais))
            && (!request.resource.data.keys().hasAny(['ads']) || request.resource.data.ads is bool)
            && (!request.resource.data.keys().hasAny(['observacoes']) || isValidString(request.resource.data.observacoes, 0, 2000))
            && (!request.resource.data.keys().hasAny(['dataPostagem']) || request.resource.data.dataPostagem is timestamp || request.resource.data.dataPostagem == null)
            && (!request.resource.data.keys().hasAny(['ordem']) || request.resource.data.ordem is number)
            && (!request.resource.data.keys().hasAny(['priorizado']) || request.resource.data.priorizado is bool)
            && (!request.resource.data.keys().hasAny(['linkMaterialBruto']) || isValidString(request.resource.data.linkMaterialBruto, 0, 2048))
            && (!request.resource.data.keys().hasAny(['linkVideoFinal']) || isValidString(request.resource.data.linkVideoFinal, 0, 2048)))
          ||
          // Public: visitor with valid empresa token can toggle priorizado and set linkMaterialBruto
          (request.resource.data.keys().hasOnly(['priorizado', 'linkMaterialBruto'])
            && request.resource.data.priorizado is bool
            && isValidString(request.resource.data.linkMaterialBruto, 0, 2048)
            && empresaToken(empresaId) == request.resource.data._token);
          allow delete: if isAdmin();
        }

        // ===============================================================
        // Notificacoes da pessoa (cliente) — admin cria, contratante lê
        // ===============================================================
        match /notificacoes/{notificacaoId} {
          allow read, delete: if true;
          allow create: if isAdmin();
        }
      }

      // ===============================================================
      // NotificacoesAdmin (contratante → admin) — token validated
      // ===============================================================
      match /notificacoesAdmin/{notificacaoId} {
        allow read, update: if isAdmin();
        allow create: if isAdmin() || (
          request.resource.data.keys().hasOnly(['tipo', 'videoId', 'videoTitulo', 'pessoaNome', 'empresaNome', 'empresaId', 'pessoaId', 'timestamp', 'lida', '_token'])
          && request.resource.data.tipo in ['priorizado', 'despriorizado', 'linkBruto']
          && isValidString(request.resource.data.videoTitulo, 1, 200)
          && isValidString(request.resource.data.pessoaNome, 1, 100)
          && isValidString(request.resource.data.empresaNome, 1, 100)
          && request.resource.data.timestamp is number
          && request.resource.data.lida == false
          && empresaToken(request.resource.data.empresaId) == request.resource.data._token
        );
        allow delete: if isAdmin();
      }
    }
  }
}
